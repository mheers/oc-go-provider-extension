{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020", "DOM"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node10",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "vscode": ["__mocks__/vscode.ts"]
    },
    "ignoreDeprecations": "6.0",
    "types": ["node", "jest"]
  },
  "include": ["tests/**/*.ts", "__mocks__/**/*.ts"]
}
